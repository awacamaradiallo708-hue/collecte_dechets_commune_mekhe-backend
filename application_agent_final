# ==================== FONCTIONS DE RECONNAISSANCE VOCALE ====================
def transcribe_audio(audio_bytes):
    """Transcrit un fichier audio en texte"""
    try:
        recognizer = sr.Recognizer()
        with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as tmp:
            tmp.write(audio_bytes)
            tmp_path = tmp.name
        
        with sr.AudioFile(tmp_path) as source:
            audio = recognizer.record(source)
            text = recognizer.recognize_google(audio, language="fr-FR")
        
        os.unlink(tmp_path)
        return text
    except sr.UnknownValueError:
        return None
    except Exception as e:
        return None

def parse_vocal_command(text):
    """Analyse le texte vocal pour extraire les informations"""
    text = text.lower()
    result = {
        "type": None,
        "valeur": None,
        "lieu": None
    }
    
    # Détection du type d'information
    if "volume" in text or "mètre cube" in text or "m3" in text:
        result["type"] = "volume"
        # Extraction du nombre (ex: "volume 5" ou "5 mètres cubes")
        match = re.search(r'(\d+(?:[.,]\d+)?)', text)
        if match:
            result["valeur"] = float(match.group(1).replace(',', '.'))
    
    elif "départ" in text or "commencer" in text:
        result["type"] = "depart"
    
    elif "fin" in text or "terminer" in text:
        result["type"] = "fin"
    
    elif "décharge" in text or "vidage" in text:
        result["type"] = "decharge"
        # Extraction du volume si présent
        match = re.search(r'(\d+(?:[.,]\d+)?)', text)
        if match:
            result["valeur"] = float(match.group(1).replace(',', '.'))
    
    elif "retour" in text or "rentrer" in text:
        result["type"] = "retour"
    
    elif "point" in text or "gps" in text or "coordonnée" in text:
        result["type"] = "gps"
        # Extraction des coordonnées
        match = re.search(r'(\d+[.,]?\d*)\s*[,;]\s*(\d+[.,]?\d*)', text)
        if match:
            result["valeur"] = f"{match.group(1)},{match.group(2)}"
    
    elif "collecte" in text and ("deux" in text or "2" in text):
        result["type"] = "collecte2"
    elif "collecte" in text and ("un" in text or "1" in text):
        result["type"] = "collecte1"
    
    return result

